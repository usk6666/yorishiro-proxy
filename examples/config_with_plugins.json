{
  "listen_addr": "127.0.0.1:8080",
  "plugins": [
    {
      "path": "examples/plugins/request_inspector.star",
      "protocol": "http",
      "hooks": ["on_receive_from_client", "on_before_send_to_server"],
      "on_error": "skip"
    },
    {
      "path": "examples/plugins/request_inspector.star",
      "protocol": "https",
      "hooks": ["on_receive_from_client", "on_before_send_to_server"],
      "on_error": "skip"
    },
    {
      "path": "examples/plugins/mock_api.star",
      "protocol": "http",
      "hooks": ["on_receive_from_client"],
      "on_error": "skip"
    }
  ]
}
