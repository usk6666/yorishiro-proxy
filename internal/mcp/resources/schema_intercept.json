{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "intercept input",
  "description": "Input schema for the intercept tool.",
  "type": "object",
  "required": ["action", "params"],
  "properties": {
    "action": {
      "type": "string",
      "description": "The action to execute.",
      "enum": ["release", "modify_and_forward", "drop"]
    },
    "params": {
      "type": "object",
      "description": "Action-specific parameters.",
      "properties": {
        "intercept_id": {
          "type": "string",
          "description": "Intercepted request ID (required for all actions)."
        },
        "override_method": {
          "type": "string",
          "description": "HTTP method override (modify_and_forward)."
        },
        "override_url": {
          "type": "string",
          "description": "URL override (modify_and_forward)."
        },
        "override_headers": {
          "type": "object",
          "description": "Header overrides (modify_and_forward).",
          "additionalProperties": { "type": "string" }
        },
        "add_headers": {
          "type": "object",
          "description": "Headers to add (modify_and_forward).",
          "additionalProperties": { "type": "string" }
        },
        "remove_headers": {
          "type": "array",
          "description": "Header names to remove (modify_and_forward).",
          "items": { "type": "string" }
        },
        "override_body": {
          "type": "string",
          "description": "Body override (modify_and_forward)."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
