{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "configure input",
  "description": "Input schema for the configure tool.",
  "type": "object",
  "properties": {
    "operation": {
      "type": "string",
      "description": "How the configuration should be applied.",
      "enum": ["merge", "replace"],
      "default": "merge"
    },
    "capture_scope": {
      "type": "object",
      "description": "Capture scope configuration.",
      "properties": {
        "add_includes": {
          "type": "array",
          "description": "(merge) Rules to add to includes.",
          "items": { "$ref": "#/$defs/scope_rule" }
        },
        "remove_includes": {
          "type": "array",
          "description": "(merge) Rules to remove from includes.",
          "items": { "$ref": "#/$defs/scope_rule" }
        },
        "add_excludes": {
          "type": "array",
          "description": "(merge) Rules to add to excludes.",
          "items": { "$ref": "#/$defs/scope_rule" }
        },
        "remove_excludes": {
          "type": "array",
          "description": "(merge) Rules to remove from excludes.",
          "items": { "$ref": "#/$defs/scope_rule" }
        },
        "includes": {
          "type": "array",
          "description": "(replace) Full list of include rules.",
          "items": { "$ref": "#/$defs/scope_rule" }
        },
        "excludes": {
          "type": "array",
          "description": "(replace) Full list of exclude rules.",
          "items": { "$ref": "#/$defs/scope_rule" }
        }
      },
      "additionalProperties": false
    },
    "tls_passthrough": {
      "type": "object",
      "description": "TLS passthrough configuration.",
      "properties": {
        "add": {
          "type": "array",
          "description": "(merge) Patterns to add.",
          "items": { "type": "string" }
        },
        "remove": {
          "type": "array",
          "description": "(merge) Patterns to remove.",
          "items": { "type": "string" }
        },
        "patterns": {
          "type": "array",
          "description": "(replace) Full list of passthrough patterns.",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "intercept_rules": {
      "type": "object",
      "description": "Intercept rules configuration.",
      "properties": {
        "add": {
          "type": "array",
          "description": "(merge) Rules to add.",
          "items": { "$ref": "#/$defs/intercept_rule" }
        },
        "remove": {
          "type": "array",
          "description": "(merge) Rule IDs to remove.",
          "items": { "type": "string" }
        },
        "enable": {
          "type": "array",
          "description": "(merge) Rule IDs to enable.",
          "items": { "type": "string" }
        },
        "disable": {
          "type": "array",
          "description": "(merge) Rule IDs to disable.",
          "items": { "type": "string" }
        },
        "rules": {
          "type": "array",
          "description": "(replace) Full list of intercept rules.",
          "items": { "$ref": "#/$defs/intercept_rule" }
        }
      },
      "additionalProperties": false
    },
    "upstream_proxy": {
      "type": ["string", "null"],
      "description": "Upstream proxy URL. Set to proxy URL to route traffic, empty string to disable. Omit to keep current."
    },
    "tls_fingerprint": {
      "type": "string",
      "description": "TLS ClientHello fingerprint profile for upstream connections.",
      "enum": ["chrome", "firefox", "safari", "edge", "random", "none"]
    },
    "max_connections": {
      "type": "integer",
      "description": "Maximum concurrent proxy connections.",
      "minimum": 1,
      "maximum": 100000
    },
    "peek_timeout_ms": {
      "type": "integer",
      "description": "Protocol detection timeout in milliseconds.",
      "minimum": 100,
      "maximum": 600000
    },
    "request_timeout_ms": {
      "type": "integer",
      "description": "HTTP request header read timeout in milliseconds.",
      "minimum": 100,
      "maximum": 600000
    },
    "budget": {
      "type": "object",
      "description": "Diagnostic session budget limits.",
      "properties": {
        "max_total_requests": {
          "type": "integer",
          "description": "Non-negative integer maximum total requests for the session. 0 means no limit.",
          "minimum": 0
        },
        "max_duration": {
          "type": "string",
          "description": "Maximum session duration as Go duration string (e.g. 30m, 1h). 0s means no limit."
        }
      },
      "additionalProperties": false
    },
    "intercept_queue": {
      "type": "object",
      "description": "Intercept queue behavior configuration.",
      "properties": {
        "timeout_ms": {
          "type": "integer",
          "description": "Timeout in milliseconds for blocked requests (minimum 1000 ms).",
          "minimum": 1000
        },
        "timeout_behavior": {
          "type": "string",
          "description": "Action when timeout is reached: auto_release (default) or auto_drop.",
          "enum": ["auto_release", "auto_drop"]
        }
      },
      "additionalProperties": false
    },
    "client_cert": {
      "type": "object",
      "description": "Global mTLS client certificate configuration.",
      "properties": {
        "cert_path": {
          "type": "string",
          "description": "PEM client certificate path (empty to remove)."
        },
        "key_path": {
          "type": "string",
          "description": "PEM client private key path (empty to remove)."
        }
      },
      "additionalProperties": false
    },
    "socks5_auth": {
      "type": "object",
      "description": "SOCKS5 authentication configuration.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["none", "password"],
          "description": "Authentication method: none or password."
        },
        "username": {
          "type": "string",
          "description": "Username for password authentication."
        },
        "password": {
          "type": "string",
          "description": "Password for password authentication."
        }
      },
      "required": ["method"],
      "additionalProperties": false
    },
    "auto_transform": {
      "type": "object",
      "description": "Auto-transform rules configuration.",
      "properties": {
        "add": {
          "type": "array",
          "description": "(merge) Rules to add.",
          "items": { "$ref": "#/$defs/transform_rule" }
        },
        "remove": {
          "type": "array",
          "description": "(merge) Rule IDs to remove.",
          "items": { "type": "string" }
        },
        "enable": {
          "type": "array",
          "description": "(merge) Rule IDs to enable.",
          "items": { "type": "string" }
        },
        "disable": {
          "type": "array",
          "description": "(merge) Rule IDs to disable.",
          "items": { "type": "string" }
        },
        "rules": {
          "type": "array",
          "description": "(replace) Full list of auto-transform rules.",
          "items": { "$ref": "#/$defs/transform_rule" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "scope_rule": {
      "type": "object",
      "description": "A scope rule. At least one field must be set.",
      "properties": {
        "hostname": {
          "type": "string",
          "description": "Hostname pattern. Exact match or wildcard (e.g. *.example.com)."
        },
        "url_prefix": {
          "type": "string",
          "description": "URL path prefix match."
        },
        "method": {
          "type": "string",
          "description": "HTTP method (e.g. GET, POST)."
        }
      },
      "additionalProperties": false
    },
    "intercept_rule": {
      "type": "object",
      "description": "An intercept rule with matching conditions.",
      "required": ["id", "enabled", "direction", "conditions"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique rule identifier."
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether the rule is active."
        },
        "direction": {
          "type": "string",
          "enum": ["request", "response", "both"],
          "description": "Applies to requests, responses, or both."
        },
        "conditions": { "$ref": "#/$defs/intercept_conditions" }
      },
      "additionalProperties": false
    },
    "intercept_conditions": {
      "type": "object",
      "description": "Matching conditions. All specified conditions are AND-ed.",
      "properties": {
        "host_pattern": {
          "type": "string",
          "description": "Regex pattern for hostname matching (port excluded)."
        },
        "path_pattern": {
          "type": "string",
          "description": "Regex pattern for URL path matching."
        },
        "methods": {
          "type": "array",
          "description": "HTTP method whitelist (case-insensitive).",
          "items": { "type": "string" }
        },
        "header_match": {
          "type": "object",
          "description": "Header name to regex pattern mapping (AND logic).",
          "additionalProperties": { "type": "string" }
        },
        "upgrade_url_pattern": {
          "type": "string",
          "description": "Regex for WebSocket upgrade URL matching (WebSocket rules only)."
        },
        "flow_id": {
          "type": "string",
          "description": "WebSocket flow ID to intercept (WebSocket rules only)."
        }
      },
      "additionalProperties": false
    },
    "transform_rule": {
      "type": "object",
      "description": "An auto-transform rule with matching conditions and action.",
      "required": ["id", "enabled", "direction", "conditions", "action"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique rule identifier."
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether the rule is active."
        },
        "priority": {
          "type": "integer",
          "description": "Execution order (lower values applied first).",
          "default": 0
        },
        "direction": {
          "type": "string",
          "enum": ["request", "response", "both"],
          "description": "Applies to requests, responses, or both."
        },
        "conditions": { "$ref": "#/$defs/intercept_conditions" },
        "action": { "$ref": "#/$defs/transform_action" }
      },
      "additionalProperties": false
    },
    "transform_action": {
      "type": "object",
      "description": "Transformation action to apply.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["add_header", "set_header", "remove_header", "replace_body"],
          "description": "Action type."
        },
        "header": {
          "type": "string",
          "description": "Header name (for header actions)."
        },
        "value": {
          "type": "string",
          "description": "Header value or replacement string."
        },
        "pattern": {
          "type": "string",
          "description": "Search regex (for replace_body)."
        }
      },
      "additionalProperties": false
    }
  }
}
