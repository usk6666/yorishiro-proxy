{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "execute input",
  "description": "Input schema for the execute tool.",
  "type": "object",
  "required": ["action", "params"],
  "properties": {
    "action": {
      "type": "string",
      "description": "The action to execute. 'replay' is a deprecated alias for 'resend'; 'replay_raw' is a deprecated alias for 'resend_raw'.",
      "enum": ["resend", "resend_raw", "tcp_replay", "replay", "replay_raw"]
    },
    "params": {
      "type": "object",
      "description": "Action-specific parameters.",
      "properties": {
        "flow_id": {
          "type": "string",
          "description": "Flow ID for resend, resend_raw, or tcp_replay."
        },
        "message_sequence": {
          "type": "integer",
          "description": "Message sequence number for WebSocket/streaming resend. Required for WebSocket flows."
        },
        "override_method": {
          "type": "string",
          "description": "HTTP method override for resend."
        },
        "override_url": {
          "type": "string",
          "description": "URL override for resend. Must include scheme and host."
        },
        "override_headers": {
          "oneOf": [
            {
              "type": "array",
              "description": "Header overrides as array of {key,value} entries (replaces matching headers). Supports duplicate keys for sending multiple values with the same header name.",
              "items": {
                "type": "object",
                "required": ["key", "value"],
                "properties": {
                  "key": { "type": "string" },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            {
              "type": "object",
              "description": "Legacy format: header overrides as key-value map (one value per key).",
              "additionalProperties": { "type": "string" }
            }
          ]
        },
        "add_headers": {
          "oneOf": [
            {
              "type": "array",
              "description": "Headers to add as array of {key,value} entries (appended to existing values). Supports duplicate keys.",
              "items": {
                "type": "object",
                "required": ["key", "value"],
                "properties": {
                  "key": { "type": "string" },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            {
              "type": "object",
              "description": "Legacy format: headers to add as key-value map (one value per key).",
              "additionalProperties": { "type": "string" }
            }
          ]
        },
        "remove_headers": {
          "type": "array",
          "description": "Header names to remove.",
          "items": { "type": "string" }
        },
        "override_body": {
          "type": "string",
          "description": "Body override for resend (text)."
        },
        "override_body_base64": {
          "type": "string",
          "description": "Body override for resend (Base64-encoded binary)."
        },
        "body_patches": {
          "type": "array",
          "description": "Partial body modification rules.",
          "items": {
            "type": "object",
            "properties": {
              "json_path": { "type": "string" },
              "value": {},
              "regex": { "type": "string" },
              "replace": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "override_host": {
          "type": "string",
          "description": "TCP connection target as host:port (independent of URL host). Subject to SSRF protection."
        },
        "follow_redirects": {
          "type": "boolean",
          "description": "Follow HTTP redirects automatically (default: false)."
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Request timeout in milliseconds (default: 30000).",
          "minimum": 1
        },
        "dry_run": {
          "type": "boolean",
          "description": "Preview modified request without sending (default: false)."
        },
        "tag": {
          "type": "string",
          "description": "Tag to attach to the result flow."
        },
        "target_addr": {
          "type": "string",
          "description": "Target address (host:port) for resend_raw and tcp_replay."
        },
        "use_tls": {
          "type": "boolean",
          "description": "Use TLS for resend_raw or tcp_replay connection."
        },
        "override_raw_base64": {
          "type": "string",
          "description": "Full raw bytes replacement (Base64-encoded) for resend_raw."
        },
        "patches": {
          "type": "array",
          "description": "Byte-level patches for resend_raw.",
          "items": {
            "type": "object",
            "properties": {
              "offset": { "type": "integer" },
              "data_base64": { "type": "string" },
              "find": { "type": "string" },
              "find_base64": { "type": "string" },
              "replace": { "type": "string" },
              "replace_base64": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "hooks": {
          "type": "object",
          "description": "Pre/post hooks for macro integration.",
          "properties": {
            "pre_send": { "type": "object" },
            "post_receive": { "type": "object" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
