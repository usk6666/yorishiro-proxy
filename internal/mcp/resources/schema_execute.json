{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "execute input",
  "description": "Input schema for the execute tool.",
  "type": "object",
  "required": ["action", "params"],
  "properties": {
    "action": {
      "type": "string",
      "description": "The action to execute. 'replay' and 'replay_raw' are accepted as deprecated aliases.",
      "enum": ["resend", "resend_raw", "delete_sessions", "fuzz", "replay", "replay_raw"]
    },
    "params": {
      "type": "object",
      "description": "Action-specific parameters.",
      "properties": {
        "session_id": {
          "type": "string",
          "description": "Session ID for resend, resend_raw, or single-session deletion."
        },
        "override_method": {
          "type": "string",
          "description": "HTTP method override for resend."
        },
        "override_url": {
          "type": "string",
          "description": "URL override for resend. Must include scheme and host."
        },
        "override_headers": {
          "type": "object",
          "description": "Header overrides for resend as key-value pairs (replaces matching headers).",
          "additionalProperties": { "type": "string" }
        },
        "add_headers": {
          "type": "object",
          "description": "Headers to add (appended to existing values for same key).",
          "additionalProperties": { "type": "string" }
        },
        "remove_headers": {
          "type": "array",
          "description": "Header names to remove.",
          "items": { "type": "string" }
        },
        "override_body": {
          "type": "string",
          "description": "Body override for resend (text)."
        },
        "override_body_base64": {
          "type": "string",
          "description": "Body override for resend (Base64-encoded binary)."
        },
        "body_patches": {
          "type": "array",
          "description": "Partial body modification rules. Each item uses either json_path+value or regex+replace.",
          "items": {
            "type": "object",
            "properties": {
              "json_path": {
                "type": "string",
                "description": "JSON path expression (e.g., $.user.name)."
              },
              "value": {
                "description": "Replacement value for json_path patch."
              },
              "regex": {
                "type": "string",
                "description": "Regular expression pattern for text-based patch."
              },
              "replace": {
                "type": "string",
                "description": "Replacement string for regex patch. Supports capture groups ($1, $2, etc.)."
              }
            },
            "additionalProperties": false
          }
        },
        "override_host": {
          "type": "string",
          "description": "TCP connection target as host:port (independent of URL host). Subject to SSRF protection."
        },
        "follow_redirects": {
          "type": "boolean",
          "description": "Follow HTTP redirects automatically (default: false)."
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Request timeout in milliseconds (default: 30000).",
          "minimum": 1
        },
        "dry_run": {
          "type": "boolean",
          "description": "Preview modified request without sending (default: false)."
        },
        "tag": {
          "type": "string",
          "description": "Tag to attach to the result session."
        },
        "target_addr": {
          "type": "string",
          "description": "Target address (host:port) for resend_raw."
        },
        "use_tls": {
          "type": "boolean",
          "description": "Use TLS for resend_raw connection."
        },
        "older_than_days": {
          "type": "integer",
          "description": "Delete sessions older than this many days. Must be >= 1.",
          "minimum": 1
        },
        "confirm": {
          "type": "boolean",
          "description": "Confirm bulk deletion (required for older_than_days or delete-all)."
        },
        "attack_type": {
          "type": "string",
          "description": "Fuzz attack type: sequential (one position at a time) or parallel (all positions simultaneously).",
          "enum": ["sequential", "parallel"]
        },
        "positions": {
          "type": "array",
          "description": "Payload injection positions for fuzz action.",
          "items": {
            "type": "object",
            "required": ["id", "location"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique position identifier (e.g., pos-0)."
              },
              "location": {
                "type": "string",
                "description": "Injection location in the request.",
                "enum": ["header", "path", "query", "body_regex", "body_json", "cookie"]
              },
              "name": {
                "type": "string",
                "description": "Header name, query key, or cookie name."
              },
              "json_path": {
                "type": "string",
                "description": "JSON path for body_json location (e.g., $.password)."
              },
              "mode": {
                "type": "string",
                "description": "Operation mode (default: replace).",
                "enum": ["replace", "add", "remove"]
              },
              "match": {
                "type": "string",
                "description": "Regex pattern for partial replacement. Capture groups replace only the group."
              },
              "payload_set": {
                "type": "string",
                "description": "Name of the payload set to use."
              }
            },
            "additionalProperties": false
          }
        },
        "payload_sets": {
          "type": "object",
          "description": "Named payload sets for fuzz action.",
          "additionalProperties": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "description": "Payload generation type.",
                "enum": ["wordlist", "file", "range", "sequence"]
              },
              "values": {
                "type": "array",
                "description": "Payload strings (for wordlist type).",
                "items": { "type": "string" }
              },
              "path": {
                "type": "string",
                "description": "Relative file path under ~/.katashiro-proxy/wordlists/ (for file type)."
              },
              "start": {
                "type": "integer",
                "description": "Range start value (for range/sequence types)."
              },
              "end": {
                "type": "integer",
                "description": "Range end value (for range/sequence types)."
              },
              "step": {
                "type": "integer",
                "description": "Range step value (for range/sequence types, default: 1)."
              },
              "format": {
                "type": "string",
                "description": "Format string for sequence type (e.g., user%04d)."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
