{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "fuzz input",
  "description": "Input schema for the fuzz tool.",
  "type": "object",
  "required": ["action", "params"],
  "properties": {
    "action": {
      "type": "string",
      "description": "The action to execute.",
      "enum": ["fuzz", "fuzz_pause", "fuzz_resume", "fuzz_cancel"]
    },
    "params": {
      "type": "object",
      "description": "Action-specific parameters.",
      "properties": {
        "session_id": {
          "type": "string",
          "description": "Template session ID for fuzz action."
        },
        "attack_type": {
          "type": "string",
          "description": "Fuzz attack type: sequential (one position at a time) or parallel (all positions simultaneously).",
          "enum": ["sequential", "parallel"]
        },
        "positions": {
          "type": "array",
          "description": "Payload injection positions for fuzz action.",
          "items": {
            "type": "object",
            "required": ["id", "location"],
            "properties": {
              "id": { "type": "string", "description": "Unique position identifier." },
              "location": { "type": "string", "description": "Injection location.", "enum": ["header", "path", "query", "body_regex", "body_json", "cookie"] },
              "name": { "type": "string", "description": "Header name, query key, or cookie name." },
              "json_path": { "type": "string", "description": "JSON path for body_json location." },
              "mode": { "type": "string", "description": "Operation mode (default: replace).", "enum": ["replace", "add", "remove"] },
              "match": { "type": "string", "description": "Regex pattern for partial replacement." },
              "payload_set": { "type": "string", "description": "Name of the payload set to use." }
            },
            "additionalProperties": false
          }
        },
        "payload_sets": {
          "type": "object",
          "description": "Named payload sets for fuzz action.",
          "additionalProperties": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["wordlist", "file", "range", "sequence"] },
              "values": { "type": "array", "items": { "type": "string" } },
              "path": { "type": "string" },
              "start": { "type": "integer" },
              "end": { "type": "integer" },
              "step": { "type": "integer" },
              "format": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "tag": {
          "type": "string",
          "description": "Tag to label the fuzz job."
        },
        "concurrency": {
          "type": "integer",
          "description": "Number of concurrent fuzz workers (default: 1, max: 100).",
          "minimum": 1,
          "maximum": 100
        },
        "rate_limit_rps": {
          "type": "number",
          "description": "Requests per second limit (0 = unlimited).",
          "minimum": 0
        },
        "delay_ms": {
          "type": "integer",
          "description": "Fixed delay between fuzz requests in milliseconds.",
          "minimum": 0
        },
        "max_retries": {
          "type": "integer",
          "description": "Retry count per failed fuzz request (default: 0).",
          "minimum": 0
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Request timeout in milliseconds (default: 30000).",
          "minimum": 1
        },
        "stop_on": {
          "type": "object",
          "description": "Automatic stop conditions for fuzz jobs.",
          "properties": {
            "status_codes": { "type": "array", "items": { "type": "integer" } },
            "error_count": { "type": "integer", "minimum": 1 },
            "latency_threshold_ms": { "type": "integer", "minimum": 1 },
            "latency_baseline_multiplier": { "type": "number", "exclusiveMinimum": 0 },
            "latency_window": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "fuzz_id": {
          "type": "string",
          "description": "Fuzz job ID for fuzz_pause, fuzz_resume, fuzz_cancel actions."
        },
        "hooks": {
          "type": "object",
          "description": "Pre/post hooks for macro integration.",
          "properties": {
            "pre_send": { "type": "object" },
            "post_receive": { "type": "object" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
